<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SQL 检查报告 - {{ summary.generatedAt | date("yyyy-MM-dd HH:mm:ss") }}</title>
    <style>
        :root {
            --primary: #3370FF;
            --primary-hover: #2966FF;
            --primary-light: #E1Eaff;
            --success: #00B628;
            --warning: #FF8800;
            --error: #F54A45;
            --info: #4C5C76;
            --bg-primary: #FFFFFF;
            --bg-secondary: #F5F6F7;
            --border: #DEE0E3;
            --text-primary: #1F2329;
            --text-secondary: #646A73;
            --text-tertiary: #8F959E;
            --shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.05);
            --shadow-md: 0 2px 8px rgba(0, 0, 0, 0.08);
            --shadow-lg: 0 4px 16px rgba(0, 0, 0, 0.12);
            --radius-sm: 4px;
            --radius-md: 8px;
            --radius-lg: 12px;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB',
                'Microsoft YaHei', 'Helvetica Neue', Helvetica, Arial, sans-serif;
            background-color: var(--bg-secondary);
            color: var(--text-primary);
            line-height: 1.6;
            font-size: 14px;
        }

        /* Header */
        .header {
            background: linear-gradient(135deg, var(--primary) 0%, #5B8FFF 100%);
            color: white;
            padding: 32px 24px;
            box-shadow: var(--shadow-md);
        }

        .header-content {
            max-width: 1400px;
            margin: 0 auto;
        }

        .header h1 {
            font-size: 28px;
            font-weight: 600;
            margin-bottom: 8px;
        }

        .header-meta {
            opacity: 0.9;
            font-size: 14px;
        }

        /* Main Container */
        .container {
            max-width: 1400px;
            margin: -24px auto 32px;
            padding: 0 24px;
        }

        /* Cards */
        .card {
            background: var(--bg-primary);
            border-radius: var(--radius-lg);
            box-shadow: var(--shadow-sm);
            margin-bottom: 24px;
            overflow: hidden;
        }

        .card-header {
            padding: 20px 24px;
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .card-title {
            font-size: 18px;
            font-weight: 600;
            color: var(--text-primary);
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .card-icon {
            width: 24px;
            height: 24px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: var(--radius-sm);
            font-size: 14px;
        }

        .card-body {
            padding: 24px;
        }

        /* Stats Grid */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 16px;
        }

        .overview {
            display: grid;
            grid-template-columns: 180px 1fr;
            gap: 24px;
            align-items: center;
        }

        .overview-score {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 10px;
        }

        .overview-label {
            font-size: 12px;
            color: var(--text-secondary);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .kpi-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
            gap: 12px;
        }

        .kpi-card {
            background: var(--bg-secondary);
            border-radius: var(--radius-md);
            padding: 14px 16px;
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        .kpi-value {
            font-size: 22px;
            font-weight: 700;
            color: var(--text-primary);
        }

        .kpi-label {
            font-size: 12px;
            color: var(--text-secondary);
            text-transform: uppercase;
            letter-spacing: 0.4px;
        }

        .kpi-sub {
            font-size: 12px;
            color: var(--text-tertiary);
        }

        .stat-item {
            background: var(--bg-secondary);
            border-radius: var(--radius-md);
            padding: 20px;
            text-align: center;
        }

        .stat-value {
            font-size: 32px;
            font-weight: 700;
            color: var(--text-primary);
            line-height: 1.2;
        }

        .stat-label {
            font-size: 13px;
            color: var(--text-secondary);
            margin-top: 4px;
        }

        .stat-item.critical .stat-value { color: var(--error); }
        .stat-item.warning .stat-value { color: var(--warning); }
        .stat-item.info .stat-value { color: var(--info); }
        .stat-item.success .stat-value { color: var(--success); }

        .insight-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
            gap: 16px;
        }

        .insight-card {
            background: var(--bg-secondary);
            border-radius: var(--radius-md);
            padding: 16px;
        }

        .insight-title {
            font-size: 13px;
            font-weight: 600;
            color: var(--text-secondary);
            margin-bottom: 12px;
            text-transform: uppercase;
            letter-spacing: 0.4px;
        }

        .progress-group {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .progress-label {
            display: flex;
            justify-content: space-between;
            font-size: 12px;
            color: var(--text-secondary);
        }

        .progress-track {
            height: 10px;
            background: #E6E8EB;
            border-radius: 6px;
            overflow: hidden;
        }

        .progress-fill {
            height: 100%;
            border-radius: 6px;
            background: var(--primary);
            transition: width 0.3s ease;
        }

        .stat-list {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .stat-row {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .stat-row-label {
            min-width: 110px;
            font-size: 12px;
            color: var(--text-secondary);
        }

        .stat-row-track {
            flex: 1;
            height: 12px;
            background: #FFFFFF;
            border-radius: 6px;
            overflow: hidden;
            border: 1px solid var(--border);
        }

        .stat-row-fill {
            height: 100%;
            background: var(--primary);
        }

        .stat-row-value {
            min-width: 36px;
            text-align: right;
            font-size: 12px;
            font-weight: 600;
            color: var(--text-primary);
        }

        /* Score Badge */
        .score-badge {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 80px;
            height: 80px;
            border-radius: 50%;
            font-size: 28px;
            font-weight: 700;
        }

        .score-badge.excellent { background: #E6F4E9; color: var(--success); }
        .score-badge.good { background: #FFF3E0; color: var(--warning); }
        .score-badge.poor { background: #FFEBEE; color: var(--error); }

        /* Table */
        .table-container {
            overflow-x: auto;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        thead th {
            background: var(--bg-secondary);
            color: var(--text-secondary);
            font-weight: 600;
            text-align: left;
            padding: 12px 16px;
            font-size: 13px;
            border-bottom: 1px solid var(--border);
        }

        tbody td {
            padding: 16px;
            border-bottom: 1px solid var(--border);
            color: var(--text-primary);
        }

        tbody tr:last-child td {
            border-bottom: none;
        }

        tbody tr:hover {
            background: var(--bg-secondary);
        }

        /* Severity Badge */
        .severity-badge {
            display: inline-flex;
            align-items: center;
            padding: 4px 12px;
            border-radius: 12px;
            font-size: 12px;
            font-weight: 500;
            gap: 6px;
        }

        .severity-badge.critical {
            background: #FFEBEE;
            color: var(--error);
        }

        .severity-badge.warning {
            background: #FFF3E0;
            color: var(--warning);
        }

        .severity-badge.info {
            background: #E8F3FF;
            color: var(--primary);
        }

        .severity-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
        }

        .severity-badge.critical .severity-dot { background: var(--error); }
        .severity-badge.warning .severity-dot { background: var(--warning); }
        .severity-badge.info .severity-dot { background: var(--primary); }

        /* SQL Code */
        .sql-code {
            background: #F8F9FA;
            border: 1px solid var(--border);
            border-radius: var(--radius-md);
            padding: 16px;
            font-family: 'Monaco', 'Menlo', 'Consolas', monospace;
            font-size: 13px;
            color: var(--text-primary);
            overflow-x: auto;
            white-space: pre-wrap;
            word-break: break-all;
            max-height: 200px;
            overflow-y: auto;
        }

        /* Collapsible Section */
        .collapsible {
            border: 1px solid var(--border);
            border-radius: var(--radius-md);
            margin-bottom: 12px;
            overflow: hidden;
        }

        .collapsible-header {
            background: var(--bg-secondary);
            padding: 14px 16px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: space-between;
            user-select: none;
            transition: background 0.2s;
        }

        .collapsible-header:hover {
            background: #EEF0F2;
        }

        .collapsible-title {
            display: flex;
            align-items: center;
            gap: 12px;
            font-weight: 500;
        }

        .collapsible-icon {
            transition: transform 0.2s;
        }

        .collapsible.expanded .collapsible-icon {
            transform: rotate(180deg);
        }

        .collapsible-body {
            display: none;
            padding: 16px;
        }

        .collapsible.expanded .collapsible-body {
            display: block;
        }

        /* Location Tags */
        .location-tag {
            display: inline-flex;
            align-items: center;
            padding: 4px 10px;
            background: var(--primary-light);
            color: var(--primary);
            border-radius: var(--radius-sm);
            font-size: 12px;
            margin: 4px;
            font-family: monospace;
        }

        /* Issue List */
        .issue-list {
            list-style: none;
        }

        .issue-item {
            display: flex;
            align-items: flex-start;
            gap: 12px;
            padding: 12px 0;
            border-bottom: 1px solid var(--border);
        }

        .issue-item:last-child {
            border-bottom: none;
        }

        .issue-icon {
            flex-shrink: 0;
            width: 20px;
            height: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
            font-size: 12px;
            margin-top: 2px;
        }

        .issue-icon.critical { background: #FFEBEE; color: var(--error); }
        .issue-icon.warning { background: #FFF3E0; color: var(--warning); }
        .issue-icon.info { background: #E8F3FF; color: var(--primary); }

        .issue-content {
            flex: 1;
        }

        .issue-message {
            font-weight: 500;
            margin-bottom: 4px;
        }

        .issue-suggestion {
            font-size: 13px;
            color: var(--text-secondary);
        }

        /* Explain Plan */
        .explain-plan {
            font-family: 'Monaco', 'Menlo', 'Consolas', monospace;
            font-size: 12px;
            background: #F8F9FA;
            border-radius: var(--radius-md);
            padding: 16px;
        }

        .explain-node {
            padding: 8px 0;
            padding-left: 20px;
            border-left: 2px solid var(--border);
        }

        .explain-node.root {
            border-left: none;
            padding-left: 0;
        }

        .explain-type {
            color: var(--primary);
            font-weight: 600;
        }

        .explain-table {
            color: var(--warning);
        }

        /* Footer */
        .footer {
            text-align: center;
            padding: 24px;
            color: var(--text-secondary);
            font-size: 13px;
        }

        /* Filters */
        .filters {
            display: flex;
            gap: 12px;
            margin-bottom: 16px;
            flex-wrap: wrap;
        }

        .filter-btn {
            padding: 8px 16px;
            border: 1px solid var(--border);
            background: white;
            border-radius: var(--radius-md);
            cursor: pointer;
            font-size: 14px;
            color: var(--text-secondary);
            transition: all 0.2s;
        }

        .filter-btn:hover {
            border-color: var(--primary);
            color: var(--primary);
        }

        .filter-btn.active {
            background: var(--primary);
            color: white;
            border-color: var(--primary);
        }

        /* Chart Section */
        .chart-section {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 24px;
            margin-top: 24px;
        }

        .chart-container {
            background: var(--bg-secondary);
            border-radius: var(--radius-md);
            padding: 20px;
        }

        .chart-title {
            font-size: 14px;
            font-weight: 600;
            color: var(--text-secondary);
            margin-bottom: 16px;
            text-align: center;
        }

        .chart-canvas {
            max-width: 100%;
            margin: 0 auto;
        }

        /* Pie Chart Legend */
        .chart-legend {
            display: flex;
            flex-wrap: wrap;
            gap: 16px;
            justify-content: center;
            margin-top: 16px;
        }

        .legend-item {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 13px;
            color: var(--text-secondary);
        }

        .legend-color {
            width: 12px;
            height: 12px;
            border-radius: 2px;
        }

        /* Bar Chart */
        .bar-chart {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .bar-item {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .bar-label {
            min-width: 120px;
            font-size: 12px;
            color: var(--text-secondary);
            text-align: right;
        }

        .bar-track {
            flex: 1;
            height: 24px;
            background: var(--bg-primary);
            border-radius: var(--radius-sm);
            overflow: hidden;
            position: relative;
        }

        .bar-fill {
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: flex-end;
            padding-right: 8px;
            font-size: 11px;
            color: white;
            font-weight: 600;
            transition: width 0.3s ease;
        }

        .bar-fill.critical { background: var(--error); }
        .bar-fill.warning { background: var(--warning); }
        .bar-fill.info { background: var(--primary); }
        .bar-fill.success { background: var(--success); }

        .bar-value {
            min-width: 40px;
            text-align: left;
            font-size: 13px;
            font-weight: 600;
            color: var(--text-primary);
        }

        /* Empty State */
        .empty-state {
            text-align: center;
            padding: 60px 24px;
            color: var(--text-secondary);
        }

        .empty-icon {
            font-size: 48px;
            margin-bottom: 16px;
            opacity: 0.5;
        }

        /* Responsive */
        @media (max-width: 768px) {
            .container {
                padding: 0 16px;
            }

            .overview {
                grid-template-columns: 1fr;
                text-align: center;
            }

            .card-body {
                padding: 16px;
            }

            .stats-grid {
                grid-template-columns: repeat(2, 1fr);
            }

            table {
                font-size: 12px;
            }

            thead th, tbody td {
                padding: 10px 12px;
            }
        }
    </style>
</head>
<body>
    <!-- Header -->
    <div class="header">
        <div class="header-content">
            <h1>🔍 SQL 检查报告</h1>
            <div class="header-meta">
                生成时间: {{ summary.generatedAt | date("yyyy-MM-dd HH:mm:ss") }}
                {% if summary.durationMs > 0 %}
                • 扫描耗时: {{ (summary.durationMs / 1000) | numberFormat }}s
                {% endif %}
            </div>
        </div>
    </div>

    <!-- Main Content -->
    <div class="container">
        <!-- Summary Card -->
        <div class="card">
            <div class="card-header">
                <div class="card-title">
                    <span class="card-icon" style="background: var(--primary-light);">📊</span>
                    扫描概览
                </div>
            </div>
            <div class="card-body">
                <div class="overview">
                    <div class="overview-score">
                        {% if summary.averageScore >= 80 %}
                        <div class="score-badge excellent">{{ summary.averageScore | numberFormat }}</div>
                        {% elseif summary.averageScore >= 60 %}
                        <div class="score-badge good">{{ summary.averageScore | numberFormat }}</div>
                        {% else %}
                        <div class="score-badge poor">{{ summary.averageScore | numberFormat }}</div>
                        {% endif %}
                        <div class="overview-label">平均得分</div>
                    </div>
                    <div class="kpi-grid">
                        <div class="kpi-card">
                            <div class="kpi-label">SQL 总量</div>
                            <div class="kpi-value">{{ summary.totalSql }}</div>
                        </div>
                        <div class="kpi-card">
                            <div class="kpi-label">解析成功</div>
                            <div class="kpi-value">{{ summary.parsedSql }}</div>
                            <div class="kpi-sub">{{ summary.parseRate | numberFormat }}% 解析率</div>
                        </div>
                        <div class="kpi-card">
                            <div class="kpi-label">可执行 EXPLAIN</div>
                            <div class="kpi-value">{{ summary.explainEligible }}</div>
                        </div>
                        <div class="kpi-card">
                            <div class="kpi-label">已执行 EXPLAIN</div>
                            <div class="kpi-value">{{ summary.explainExecuted }}</div>
                            <div class="kpi-sub">{{ summary.explainCoverage | numberFormat }}% 覆盖率</div>
                        </div>
                        <div class="kpi-card">
                            <div class="kpi-label">问题总量</div>
                            <div class="kpi-value">{{ summary.totalIssues }}</div>
                            <div class="kpi-sub">
                                严重 {{ summary.criticalIssues }} · 警告 {{ summary.warningIssues }} · 提示 {{ summary.infoIssues }}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Coverage & Distribution -->
        <div class="card">
            <div class="card-header">
                <div class="card-title">
                    <span class="card-icon" style="background: var(--primary-light);">🧭</span>
                    覆盖率与分布
                </div>
            </div>
            <div class="card-body">
                <div class="insight-grid">
                    <div class="insight-card">
                        <div class="insight-title">解析与 EXPLAIN 覆盖率</div>
                        <div class="progress-group">
                            <div>
                                <div class="progress-label">
                                    <span>解析覆盖率</span>
                                    <span>{{ summary.parsedSql }}/{{ summary.totalSql }}</span>
                                </div>
                                <div class="progress-track">
                                    <div class="progress-fill" style="width: {{ summary.parseRate | numberFormat }}%;"></div>
                                </div>
                            </div>
                            <div>
                                <div class="progress-label">
                                    <span>EXPLAIN 覆盖率</span>
                                    <span>{{ summary.explainExecuted }}/{{ summary.explainEligible }}</span>
                                </div>
                                <div class="progress-track">
                                    <div class="progress-fill" style="width: {{ summary.explainCoverage | numberFormat }}%;"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="insight-card">
                        <div class="insight-title">SQL 分类</div>
                        <div class="stat-list">
                            {% if summary.categoryStats is empty %}
                            <div class="stat-row-label">暂无数据</div>
                            {% else %}
                            {% for item in summary.categoryStats %}
                            <div class="stat-row">
                                <div class="stat-row-label">{{ item.label }}</div>
                                <div class="stat-row-track">
                                    <div class="stat-row-fill" style="width: {{ item.ratio | numberFormat }}%;"></div>
                                </div>
                                <div class="stat-row-value">{{ item.count }}</div>
                            </div>
                            {% endfor %}
                            {% endif %}
                        </div>
                    </div>
                    <div class="insight-card">
                        <div class="insight-title">EXPLAIN 可执行性</div>
                        <div class="stat-list">
                            {% if summary.explainEligibilityStats is empty %}
                            <div class="stat-row-label">暂无数据</div>
                            {% else %}
                            {% for item in summary.explainEligibilityStats %}
                            <div class="stat-row">
                                <div class="stat-row-label">{{ item.label }}</div>
                                <div class="stat-row-track">
                                    <div class="stat-row-fill" style="width: {{ item.ratio | numberFormat }}%;"></div>
                                </div>
                                <div class="stat-row-value">{{ item.count }}</div>
                            </div>
                            {% endfor %}
                            {% endif %}
                        </div>
                    </div>
                    <div class="insight-card">
                        <div class="insight-title">SQL 来源类型</div>
                        <div class="stat-list">
                            {% if summary.sourceTypeStats is empty %}
                            <div class="stat-row-label">暂无数据</div>
                            {% else %}
                            {% for item in summary.sourceTypeStats %}
                            <div class="stat-row">
                                <div class="stat-row-label">{{ item.label }}</div>
                                <div class="stat-row-track">
                                    <div class="stat-row-fill" style="width: {{ item.ratio | numberFormat }}%;"></div>
                                </div>
                                <div class="stat-row-value">{{ item.count }}</div>
                            </div>
                            {% endfor %}
                            {% endif %}
                        </div>
                    </div>
                    <div class="insight-card">
                        <div class="insight-title">合法性</div>
                        <div class="stat-list">
                            {% if summary.validityStats is empty %}
                            <div class="stat-row-label">暂无数据</div>
                            {% else %}
                            {% for item in summary.validityStats %}
                            <div class="stat-row">
                                <div class="stat-row-label">{{ item.label }}</div>
                                <div class="stat-row-track">
                                    <div class="stat-row-fill" style="width: {{ item.ratio | numberFormat }}%;"></div>
                                </div>
                                <div class="stat-row-value">{{ item.count }}</div>
                            </div>
                            {% endfor %}
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Issue Hotspots -->
        <div class="card">
            <div class="card-header">
                <div class="card-title">
                    <span class="card-icon" style="background: var(--primary-light);">🔥</span>
                    问题热点
                </div>
            </div>
            <div class="card-body">
                <div class="insight-grid">
                    <div class="insight-card">
                        <div class="insight-title">静态规则</div>
                        <div class="stat-list">
                            {% if summary.staticIssueStats is empty %}
                            <div class="stat-row-label">暂无静态问题</div>
                            {% else %}
                            {% for item in summary.staticIssueStats %}
                            <div class="stat-row">
                                <div class="stat-row-label">{{ item.label }}</div>
                                <div class="stat-row-track">
                                    <div class="stat-row-fill" style="width: {{ item.ratio | numberFormat }}%;"></div>
                                </div>
                                <div class="stat-row-value">{{ item.count }}</div>
                            </div>
                            {% endfor %}
                            {% endif %}
                        </div>
                    </div>
                    <div class="insight-card">
                        <div class="insight-title">EXPLAIN 规则</div>
                        <div class="stat-list">
                            {% if summary.explainIssueStats is empty %}
                            <div class="stat-row-label">暂无 EXPLAIN 问题</div>
                            {% else %}
                            {% for item in summary.explainIssueStats %}
                            <div class="stat-row">
                                <div class="stat-row-label">{{ item.label }}</div>
                                <div class="stat-row-track">
                                    <div class="stat-row-fill" style="width: {{ item.ratio | numberFormat }}%;"></div>
                                </div>
                                <div class="stat-row-value">{{ item.count }}</div>
                            </div>
                            {% endfor %}
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Charts Section -->
        {% if summary.totalIssues > 0 %}
        <div class="card">
            <div class="card-header">
                <div class="card-title">
                    <span class="card-icon" style="background: var(--primary-light);">📈</span>
                    问题分布
                </div>
            </div>
            <div class="card-body">
                <div class="chart-section">
                    <!-- Pie Chart -->
                    <div class="chart-container">
                        <div class="chart-title">严重程度分布</div>
                        <canvas id="pieChart" class="chart-canvas" width="200" height="200"></canvas>
                        <div class="chart-legend">
                            <div class="legend-item">
                                <div class="legend-color" style="background: var(--error);"></div>
                                <span>严重 ({{ summary.criticalIssues }})</span>
                            </div>
                            <div class="legend-item">
                                <div class="legend-color" style="background: var(--warning);"></div>
                                <span>警告 ({{ summary.warningIssues }})</span>
                            </div>
                            <div class="legend-item">
                                <div class="legend-color" style="background: var(--primary);"></div>
                                <span>提示 ({{ summary.infoIssues }})</span>
                            </div>
                        </div>
                    </div>

                    <!-- Bar Chart -->
                    <div class="chart-container">
                        <div class="chart-title">问题构成</div>
                        <div class="bar-chart" id="barChart">
                            {% if summary.criticalIssues > 0 %}
                            <div class="bar-item">
                                <div class="bar-label">严重</div>
                                <div class="bar-track">
                                    <div class="bar-fill critical" style="width: {{ (summary.criticalIssues * 100 / summary.totalIssues) | numberFormat }}%;">
                                        {{ (summary.criticalIssues * 100 / summary.totalIssues) | numberFormat }}%
                                    </div>
                                </div>
                                <div class="bar-value">{{ summary.criticalIssues }}</div>
                            </div>
                            {% endif %}
                            {% if summary.warningIssues > 0 %}
                            <div class="bar-item">
                                <div class="bar-label">警告</div>
                                <div class="bar-track">
                                    <div class="bar-fill warning" style="width: {{ (summary.warningIssues * 100 / summary.totalIssues) | numberFormat }}%;">
                                        {{ (summary.warningIssues * 100 / summary.totalIssues) | numberFormat }}%
                                    </div>
                                </div>
                                <div class="bar-value">{{ summary.warningIssues }}</div>
                            </div>
                            {% endif %}
                            {% if summary.infoIssues > 0 %}
                            <div class="bar-item">
                                <div class="bar-label">提示</div>
                                <div class="bar-track">
                                    <div class="bar-fill info" style="width: {{ (summary.infoIssues * 100 / summary.totalIssues) | numberFormat }}%;">
                                        {{ (summary.infoIssues * 100 / summary.totalIssues) | numberFormat }}%
                                    </div>
                                </div>
                                <div class="bar-value">{{ summary.infoIssues }}</div>
                            </div>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        </div>
        {% endif %}

        <!-- SQL List -->
        <div class="card">
            <div class="card-header">
                <div class="card-title">
                    <span class="card-icon" style="background: var(--primary-light);">📝</span>
                    SQL 语句列表 ({{ sqlStatements | length }})
                </div>
            </div>
            <div class="card-body">
                <div class="filters">
                    <button class="filter-btn active" onclick="filterBySeverity('all')">全部</button>
                    <button class="filter-btn" onclick="filterBySeverity('critical')">严重</button>
                    <button class="filter-btn" onclick="filterBySeverity('warning')">警告</button>
                    <button class="filter-btn" onclick="filterBySeverity('info')">提示</button>
                </div>

                {% if sqlStatements is empty %}
                <div class="empty-state">
                    <div class="empty-icon">✓</div>
                    <p>未发现 SQL 语句</p>
                </div>
                {% else %}
                <div class="table-container">
                    <table>
                        <thead>
                            <tr>
                                <th style="width: 80px;">严重级别</th>
                                <th style="width: 80px;">评分</th>
                                <th>SQL 语句</th>
                                <th style="width: 120px;">位置</th>
                                <th style="width: 80px;">详情</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for sql in sqlStatements %}
                            <tr data-severity="{{ sql.severity | lower }}">
                                <td>
                                    <span class="severity-badge {{ sql.severity | lower }}">
                                        <span class="severity-dot"></span>
                                        {% if sql.severity == 'CRITICAL' %}严重
                                        {% elseif sql.severity == 'WARNING' %}警告
                                        {% else %}提示{% endif %}
                                    </span>
                                </td>
                                <td>
                                    <strong>{{ sql.score }}</strong>
                                </td>
                                <td>
                                    <div class="sql-code">{{ sql.abstractSql }}</div>
                                    {% if sql.originalSql != sql.abstractSql %}
                                    <details style="margin-top: 8px;">
                                        <summary style="cursor: pointer; color: var(--primary); font-size: 12px;">查看原始 SQL</summary>
                                        <div class="sql-code" style="margin-top: 8px;">{{ sql.originalSql }}</div>
                                    </details>
                                    {% endif %}
                                </td>
                                <td>
                                    {% for location in sql.locations %}
                                    <span class="location-tag">{{ location.fileName }}:{{ location.startLine }}</span>
                                    {% endfor %}
                                </td>
                                <td>
                                    <button class="filter-btn" onclick="toggleDetails('{{ sql.id }}')">查看</button>
                                </td>
                            </tr>

                            <!-- Details Row (Hidden by default) -->
                            <tr id="details-{{ sql.id }}" style="display: none;">
                                <td colspan="5" style="padding: 0;">
                                    <div style="padding: 20px; background: var(--bg-secondary);">
                                        <!-- Preprocess Info -->
                                        <h4 style="margin-bottom: 12px;">🧹 预处理信息</h4>
                                        <div style="font-size: 13px; color: var(--text-secondary); margin-bottom: 8px;">
                                            分类: {{ sql.category }} |
                                            合法性: {{ sql.validity }} |
                                            Explain 可执行性: {{ sql.explainEligibility }}
                                        </div>
                                        {% if sql.preprocessErrorReason %}
                                        <div style="font-size: 12px; color: var(--warning); margin-bottom: 8px;">
                                            {{ sql.preprocessErrorReason }}
                                        </div>
                                        {% endif %}
                                        {% if sql.normalizedSql %}
                                        <details style="margin-bottom: 8px;">
                                            <summary style="cursor: pointer; color: var(--primary); font-size: 12px;">查看规范化 SQL</summary>
                                            <div class="sql-code" style="margin-top: 8px;">{{ sql.normalizedSql }}</div>
                                        </details>
                                        {% endif %}
                                        {% if sql.explainSql %}
                                        <details style="margin-bottom: 12px;">
                                            <summary style="cursor: pointer; color: var(--primary); font-size: 12px;">查看 Explain SQL</summary>
                                            <div class="sql-code" style="margin-top: 8px;">{{ sql.explainSql }}</div>
                                        </details>
                                        {% endif %}
                                        <!-- Static Analysis -->
                                        {% if sql.staticAnalysis is defined and sql.staticAnalysis is not null %}
                                        <h4 style="margin-bottom: 12px;">📋 静态分析结果</h4>
                                        {% if sql.staticAnalysis.issues is defined and sql.staticAnalysis.issues is not null and sql.staticAnalysis.issues.size() > 0 %}
                                        <ul class="issue-list">
                                            {% for issue in sql.staticAnalysis.issues %}
                                            <li class="issue-item">
                                                <span class="issue-icon {{ issue.severity | lower }}">!</span>
                                                <div class="issue-content">
                                                    <div class="issue-message">{{ issue.message }}</div>
                                                    {% if issue.suggestion %}
                                                    <div class="issue-suggestion">💡 {{ issue.suggestion }}</div>
                                                    {% endif %}
                                                </div>
                                            </li>
                                            {% endfor %}
                                        </ul>
                                        {% else %}
                                        <p style="color: var(--text-secondary);">未发现问题</p>
                                        {% endif %}
                                        {% else %}
                                        <h4 style="margin-bottom: 12px;">📋 静态分析结果</h4>
                                        <p style="color: var(--text-secondary);">未发现问题</p>
                                        {% endif %}

                                        <!-- EXPLAIN Analysis -->
                                        {% if sql.explainEligibility is defined and sql.explainEligibility == 'NOT_SUPPORTED' %}
                                        <h4 style="margin: 20px 0 12px;">📊 执行计划分析 (EXPLAIN)</h4>
                                        <p style="color: var(--text-secondary);">
                                            已跳过: {{ sql.explainEligibility }}
                                            {% if sql.preprocessErrorReason %} ({{ sql.preprocessErrorReason }}){% endif %}
                                        </p>
                                        {% elseif sql.explainAnalysis is defined and sql.explainAnalysis is not null and sql.explainAnalysis.plan is defined and sql.explainAnalysis.plan is not null %}
                                        <h4 style="margin: 20px 0 12px;">📊 执行计划分析 (EXPLAIN)</h4>
                                        <div class="explain-plan">
                                            {% for node in sql.explainAnalysis.plan.nodes %}
                                            <div class="explain-node {{ node.id == '1' ? 'root' : '' }}">
                                                <span class="explain-type">{{ node.selectType }}</span>
                                                <span> | </span>
                                                <span class="explain-type">{{ node.type }}</span>
                                                <span> | </span>
                                                <span class="explain-table">{{ node.table }}</span>
                                                {% if node.key %}
                                                <span> | 索引: {{ node.key }}</span>
                                                {% endif %}
                                                {% if node.rows %}
                                                <span> | 扫描行数: {{ node.rows }}</span>
                                                {% endif %}
                                                {% if node.extra %}
                                                <div style="color: var(--text-secondary); margin-top: 4px;">{{ node.extra }}</div>
                                                {% endif %}
                                            </div>
                                            {% endfor %}
                                        </div>
                                        {% if sql.explainAnalysis.issues is defined and sql.explainAnalysis.issues is not null and sql.explainAnalysis.issues.size() > 0 %}
                                        <ul class="issue-list" style="margin-top: 12px;">
                                            {% for issue in sql.explainAnalysis.issues %}
                                            <li class="issue-item">
                                                <span class="issue-icon {{ issue.severity | lower }}">!</span>
                                                <div class="issue-content">
                                                    <div class="issue-message">{{ issue.message }}</div>
                                                    {% if issue.suggestion %}
                                                    <div class="issue-suggestion">💡 {{ issue.suggestion }}</div>
                                                    {% endif %}
                                                </div>
                                            </li>
                                            {% endfor %}
                                        </ul>
                                        {% endif %}
                                        {% elseif sql.explainAnalysis is defined and sql.explainAnalysis is not null %}
                                        <h4 style="margin: 20px 0 12px;">📊 执行计划分析 (EXPLAIN)</h4>
                                        <p style="color: var(--text-secondary);">动态分析需要配置数据库连接，当前未启用</p>
                                        {% else %}
                                        <h4 style="margin: 20px 0 12px;">📊 执行计划分析 (EXPLAIN)</h4>
                                        <p style="color: var(--text-secondary);">动态分析需要配置数据库连接，当前未启用</p>
                                        {% endif %}

                                        <!-- Expert Analysis -->
                                        {% if sql.expertAnalysis is defined and sql.expertAnalysis is not null and sql.expertAnalysis.recommendations is defined and sql.expertAnalysis.recommendations is not null and sql.expertAnalysis.recommendations.size() > 0 %}
                                        <h4 style="margin: 20px 0 12px;">🎯 专家建议</h4>
                                        <ul class="issue-list">
                                            {% for rec in sql.expertAnalysis.recommendations %}
                                            <li class="issue-item">
                                                <span class="issue-icon info">★</span>
                                                <div class="issue-content">
                                                    <div class="issue-message">{{ rec.title }}</div>
                                                    <div style="font-size: 13px; color: var(--text-secondary); margin: 4px 0;">{{ rec.description }}</div>
                                                    <div class="issue-suggestion">💡 {{ rec.suggestion }}</div>
                                                    {% if rec.expectedBenefit %}
                                                    <div style="font-size: 12px; color: var(--success); margin-top: 4px;">
                                                        ✓ {{ rec.expectedBenefit }}
                                                    </div>
                                                    {% endif %}
                                                </div>
                                            </li>
                                            {% endfor %}
                                        </ul>
                                        {% else %}
                                        {% if sql.expertAnalysis is defined and sql.expertAnalysis is not null %}
                                        <h4 style="margin: 20px 0 12px;">🎯 专家建议</h4>
                                        <p style="color: var(--text-secondary);">暂无建议</p>
                                        {% endif %}
                                        {% endif %}
                                    </div>
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
                {% endif %}
            </div>
        </div>
    </div>

    <!-- Footer -->
    <div class="footer">
        <p>由 <strong>SQL Checker</strong> 生成 | v1.0.0</p>
        <p style="margin-top: 4px;">扫描耗时: {{ (summary.durationMs / 1000) | numberFormat }}秒</p>
    </div>

    <script>
        // Chart data from template
        const chartData = {
            critical: {{ summary.criticalIssues }},
            warning: {{ summary.warningIssues }},
            info: {{ summary.infoIssues }},
            total: {{ summary.totalIssues }}
        };

        // Draw pie chart
        function drawPieChart() {
            const canvas = document.getElementById('pieChart');
            if (!canvas) return;

            const ctx = canvas.getContext('2d');
            const centerX = canvas.width / 2;
            const centerY = canvas.height / 2;
            const radius = Math.min(centerX, centerY) - 10;

            const data = [
                { value: chartData.critical, color: '#F54A45', label: 'Critical' },
                { value: chartData.warning, color: '#FF8800', label: 'Warning' },
                { value: chartData.info, color: '#3370FF', label: 'Info' }
            ].filter(d => d.value > 0);

            if (data.length === 0) {
                // Draw empty state
                ctx.beginPath();
                ctx.arc(centerX, centerY, radius, 0, 2 * Math.PI);
                ctx.fillStyle = '#DEE0E3';
                ctx.fill();
                return;
            }

            const total = data.reduce((sum, d) => sum + d.value, 0);
            let startAngle = -Math.PI / 2;

            data.forEach(item => {
                const sliceAngle = (item.value / total) * 2 * Math.PI;

                ctx.beginPath();
                ctx.moveTo(centerX, centerY);
                ctx.arc(centerX, centerY, radius, startAngle, startAngle + sliceAngle);
                ctx.closePath();
                ctx.fillStyle = item.color;
                ctx.fill();

                // Add white border between slices
                ctx.strokeStyle = '#FFFFFF';
                ctx.lineWidth = 2;
                ctx.stroke();

                startAngle += sliceAngle;
            });

            // Draw center circle (donut chart style)
            ctx.beginPath();
            ctx.arc(centerX, centerY, radius * 0.5, 0, 2 * Math.PI);
            ctx.fillStyle = '#F5F6F7';
            ctx.fill();

            // Draw total in center
            ctx.fillStyle = '#1F2329';
            ctx.font = 'bold 24px sans-serif';
            ctx.textAlign = 'center';
            ctx.textBaseline = 'middle';
            ctx.fillText(total.toString(), centerX, centerY);
        }

        // Toggle details
        function toggleDetails(id) {
            const row = document.getElementById('details-' + id);
            if (row.style.display === 'none') {
                row.style.display = 'table-row';
            } else {
                row.style.display = 'none';
            }
        }

        // Filter by severity
        function filterBySeverity(severity) {
            const rows = document.querySelectorAll('tbody tr[data-severity]');
            const buttons = document.querySelectorAll('.filter-btn');

            // Update button states
            buttons.forEach(btn => btn.classList.remove('active'));
            event.target.classList.add('active');

            // Filter rows
            rows.forEach(row => {
                if (severity === 'all' || row.dataset.severity === severity) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
        }

        // Collapsible sections
        document.querySelectorAll('.collapsible-header').forEach(header => {
            header.addEventListener('click', () => {
                header.parentElement.classList.toggle('expanded');
            });
        });

        // Initialize charts on page load
        window.addEventListener('load', () => {
            drawPieChart();
        });
    </script>
</body>
</html>
