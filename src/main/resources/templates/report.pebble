<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SQL 检查报告 - {{ summary.generatedAt | date("yyyy-MM-dd HH:mm:ss") }}</title>
    <style>
        :root {
            /* 光谱色系 - Spectrum Colors */
            --spectrum-red: #FF4D4F;
            --spectrum-orange: #FF7A45;
            --spectrum-yellow: #FFC53D;
            --spectrum-green: #52C41A;
            --spectrum-blue: #1890FF;
            --spectrum-indigo: #597EF7;
            --spectrum-violet: #722ED1;

            /* 语义色彩 - 基于光谱 */
            --primary: #1890FF;
            --primary-hover: #40A9FF;
            --primary-light: #E6F7FF;
            --success: #52C41A;
            --warning: #FF7A45;
            --error: #FF4D4F;
            --info: #597EF7;

            /* 背景色 */
            --bg-primary: #FFFFFF;
            --bg-secondary: #F6F8FA;
            --bg-dark: #0D1117;
            --border: #D0D7DE;

            /* 文字色 */
            --text-primary: #24292F;
            --text-secondary: #57606A;
            --text-tertiary: #8B949E;

            /* 阴影 */
            --shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.04);
            --shadow-md: 0 2px 8px rgba(0, 0, 0, 0.08);
            --shadow-lg: 0 4px 16px rgba(0, 0, 0, 0.12);

            /* 圆角 */
            --radius-sm: 4px;
            --radius-md: 8px;
            --radius-lg: 12px;

            /* 光谱渐变 */
            --spectrum-gradient: linear-gradient(90deg,
                #FF4D4F 0%,
                #FF7A45 17%,
                #FFC53D 33%,
                #52C41A 50%,
                #1890FF 67%,
                #597EF7 83%,
                #722ED1 100%
            );
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB',
                'Microsoft YaHei', 'Helvetica Neue', Helvetica, Arial, sans-serif;
            background-color: var(--bg-secondary);
            color: var(--text-primary);
            line-height: 1.6;
            font-size: 14px;
        }

        /* Header */
        .header {
            background: var(--bg-primary);
            color: var(--text-primary);
            padding: 0;
            box-shadow: var(--shadow-sm);
            position: relative;
            border-bottom: 1px solid var(--border);
        }

        .header::before {
            content: '';
            display: block;
            height: 3px;
            background: var(--spectrum-gradient);
        }

        .header-content {
            max-width: 1400px;
            margin: 0 auto;
            padding: 20px 24px;
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .header-logo {
            width: 44px;
            height: 44px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: var(--bg-dark);
            border-radius: var(--radius-md);
            padding: 6px;
        }

        .header h1 {
            font-size: 20px;
            font-weight: 600;
            margin-bottom: 2px;
            background: var(--spectrum-gradient);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .header-subtitle {
            font-size: 13px;
            color: var(--text-secondary);
        }

        .header-meta {
            margin-left: auto;
            text-align: right;
            font-size: 12px;
            color: var(--text-secondary);
        }

        /* Main Container */
        .container {
            max-width: 1400px;
            margin: 24px auto 32px;
            padding: 0 24px;
        }

        /* Cards */
        .card {
            background: var(--bg-primary);
            border-radius: var(--radius-lg);
            box-shadow: var(--shadow-sm);
            margin-bottom: 24px;
            overflow: hidden;
            border: 1px solid var(--border);
            position: relative;
        }

        .card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 2px;
            background: var(--spectrum-gradient);
            opacity: 0.8;
        }

        .card-header {
            padding: 16px 24px;
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: var(--bg-secondary);
        }

        .card-title {
            font-size: 16px;
            font-weight: 600;
            color: var(--text-primary);
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .card-icon {
            width: 22px;
            height: 22px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: var(--radius-sm);
            font-size: 13px;
        }

        .card-body {
            padding: 24px;
        }

        /* Stats Grid */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 16px;
        }

        .overview {
            display: grid;
            grid-template-columns: 180px 1fr;
            gap: 24px;
            align-items: center;
        }

        .overview-score {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 10px;
        }

        .overview-label {
            font-size: 12px;
            color: var(--text-secondary);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .kpi-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
            gap: 12px;
        }

        .kpi-card {
            background: var(--bg-primary);
            border-radius: var(--radius-md);
            padding: 14px 16px;
            display: flex;
            flex-direction: column;
            gap: 6px;
            border: 1px solid var(--border);
            border-left: 3px solid var(--spectrum-blue);
        }

        .kpi-card:nth-child(1) { border-left-color: var(--spectrum-blue); }
        .kpi-card:nth-child(2) { border-left-color: var(--spectrum-green); }
        .kpi-card:nth-child(3) { border-left-color: var(--spectrum-indigo); }
        .kpi-card:nth-child(4) { border-left-color: var(--spectrum-violet); }
        .kpi-card:nth-child(5) { border-left-color: var(--spectrum-orange); }

        .kpi-value {
            font-size: 22px;
            font-weight: 700;
            color: var(--text-primary);
        }

        .kpi-label {
            font-size: 12px;
            color: var(--text-secondary);
            text-transform: uppercase;
            letter-spacing: 0.4px;
        }

        .kpi-sub {
            font-size: 12px;
            color: var(--text-tertiary);
        }

        .stat-item {
            background: var(--bg-secondary);
            border-radius: var(--radius-md);
            padding: 20px;
            text-align: center;
        }

        .stat-value {
            font-size: 32px;
            font-weight: 700;
            color: var(--text-primary);
            line-height: 1.2;
        }

        .stat-label {
            font-size: 13px;
            color: var(--text-secondary);
            margin-top: 4px;
        }

        .stat-item.critical .stat-value { color: var(--error); }
        .stat-item.warning .stat-value { color: var(--warning); }
        .stat-item.info .stat-value { color: var(--info); }
        .stat-item.success .stat-value { color: var(--success); }

        .insight-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
            gap: 16px;
        }

        .insight-card {
            background: var(--bg-secondary);
            border-radius: var(--radius-md);
            padding: 16px;
        }

        .insight-title {
            font-size: 13px;
            font-weight: 600;
            color: var(--text-secondary);
            margin-bottom: 12px;
            text-transform: uppercase;
            letter-spacing: 0.4px;
        }

        .progress-group {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .progress-label {
            display: flex;
            justify-content: space-between;
            font-size: 12px;
            color: var(--text-secondary);
        }

        .progress-track {
            height: 10px;
            background: #E6E8EB;
            border-radius: 6px;
            overflow: hidden;
        }

        .progress-fill {
            height: 100%;
            border-radius: 6px;
            background: var(--primary);
            transition: width 0.3s ease;
        }

        .stat-list {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .stat-row {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .stat-row-label {
            min-width: 110px;
            font-size: 12px;
            color: var(--text-secondary);
        }

        .stat-row-track {
            flex: 1;
            height: 12px;
            background: #FFFFFF;
            border-radius: 6px;
            overflow: hidden;
            border: 1px solid var(--border);
        }

        .stat-row-fill {
            height: 100%;
            background: var(--primary);
        }

        .stat-row-value {
            min-width: 36px;
            text-align: right;
            font-size: 12px;
            font-weight: 600;
            color: var(--text-primary);
        }

        /* Score Badge */
        .score-badge {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 80px;
            height: 80px;
            border-radius: 50%;
            font-size: 28px;
            font-weight: 700;
            box-shadow: var(--shadow-sm);
        }

        .score-badge.excellent {
            background: linear-gradient(135deg, #F6FFED 0%, #D9F7BE 100%);
            color: var(--spectrum-green);
            border: 2px solid #B7EB8F;
        }
        .score-badge.good {
            background: linear-gradient(135deg, #FFF7E6 0%, #FFE7BA 100%);
            color: var(--spectrum-orange);
            border: 2px solid #FFD591;
        }
        .score-badge.poor {
            background: linear-gradient(135deg, #FFF1F0 0%, #FFCCC7 100%);
            color: var(--spectrum-red);
            border: 2px solid #FFA39E;
        }

        .scan-meta {
            display: flex;
            flex-wrap: wrap;
            gap: 10px 16px;
            align-items: center;
            padding: 10px 12px;
            border-radius: 12px;
            background: var(--bg-secondary);
            border: 1px solid var(--border);
            margin-bottom: 16px;
        }

        .scan-meta-item {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            font-size: 12px;
            color: var(--text-secondary);
        }

        .scan-meta-label {
            font-weight: 600;
            color: var(--text-primary);
        }

        .scan-meta-value {
            font-weight: 600;
            color: var(--text-primary);
        }

        .scan-meta-sub {
            color: var(--text-secondary);
            font-weight: 500;
        }

        .scan-meta-path .scan-meta-value {
            max-width: 360px;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
            display: inline-block;
            vertical-align: bottom;
        }

        .has-tooltip {
            position: relative;
            cursor: help;
        }

        .has-tooltip::after {
            content: attr(data-tooltip);
            position: absolute;
            left: 50%;
            bottom: calc(100% + 10px);
            transform: translateX(-50%);
            background: #1F2A37;
            color: #FFFFFF;
            padding: 6px 8px;
            border-radius: 6px;
            font-size: 11px;
            line-height: 1.35;
            white-space: normal;
            min-width: 180px;
            max-width: 320px;
            word-break: break-word;
            text-align: left;
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.18);
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.15s ease, transform 0.15s ease;
            z-index: 10;
        }

        .has-tooltip::before {
            content: "";
            position: absolute;
            left: 50%;
            bottom: calc(100% + 4px);
            transform: translateX(-50%);
            border-width: 6px 6px 0 6px;
            border-style: solid;
            border-color: #1F2A37 transparent transparent transparent;
            opacity: 0;
            transition: opacity 0.15s ease, transform 0.15s ease;
            z-index: 10;
        }

        .has-tooltip:hover::after,
        .has-tooltip:hover::before {
            opacity: 1;
            transform: translateX(-50%) translateY(-2px);
        }

        .has-tooltip[data-tooltip=""]::after,
        .has-tooltip[data-tooltip=""]::before {
            display: none;
        }

        /* Table */
        .table-container {
            overflow-x: auto;
            max-height: 800px;
            overflow-y: auto;
            position: relative;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        thead th {
            position: sticky;
            top: 0;
            background: var(--bg-secondary);
            z-index: 10;
            box-shadow: 0 1px 0 var(--border);
        }

        tbody td {
            padding: 12px;
            border-bottom: 1px solid var(--border);
            color: var(--text-primary);
        }

        tbody tr:last-child td {
            border-bottom: none;
        }

        tbody tr:hover {
            background: var(--bg-secondary);
        }

        /* Severity Badge */
        .severity-badge {
            display: inline-flex;
            align-items: center;
            padding: 3px 8px;
            border-radius: 12px;
            font-size: 11px;
            font-weight: 500;
            gap: 6px;
        }

        .severity-badge.critical {
            background: #FFF1F0;
            color: #CF1322;
            border: 1px solid #FFA39E;
        }

        .severity-badge.warning {
            background: #FFF7E6;
            color: #D46B08;
            border: 1px solid #FFD591;
        }

        .severity-badge.info {
            background: #F0F5FF;
            color: #2F54EB;
            border: 1px solid #ADC6FF;
        }

        .severity-dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            animation: pulse 2s infinite;
        }

        .severity-badge.critical .severity-dot { background: var(--error); }
        .severity-badge.warning .severity-dot { background: var(--warning); }
        .severity-badge.info .severity-dot { background: var(--primary); }

        /* SQL Code */
        .sql-code-container {
            position: relative;
        }

        .sql-code {
            position: relative;
            padding-right: 40px; /* Space for copy button */
            font-family: 'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, monospace;
            background-color: var(--bg-secondary);
            padding: 8px 12px;
            border-radius: 4px;
            border: 1px solid var(--border);
            white-space: pre-wrap;
            word-break: break-all;
        }

        .copy-btn {
            position: absolute;
            top: 4px;
            right: 4px;
            padding: 4px 8px;
            background: var(--bg-primary);
            border: 1px solid var(--border);
            border-radius: 4px;
            font-size: 12px;
            cursor: pointer;
            color: var(--text-secondary);
            transition: all 0.2s;
            opacity: 0;
        }

        .sql-code-container:hover .copy-btn {
            opacity: 1;
        }

        .copy-btn:hover {
            background: var(--primary-light);
            color: var(--primary);
            border-color: var(--primary);
        }

        /* Simple Syntax Highlighting */
        .hl-keyword { color: #d73a49; font-weight: bold; } /* Red for keywords */
        .hl-string { color: #032f62; } /* Blue for strings */
        .hl-number { color: #005cc5; } /* Dark blue for numbers */
        .hl-comment { color: #6a737d; font-style: italic; } /* Gray for comments */
        .hl-function { color: #6f42c1; } /* Purple for functions */

        /* Footer */
        .footer {
            text-align: center;
            padding: 24px 24px 32px;
            color: var(--text-secondary);
            font-size: 13px;
            position: relative;
        }

        .footer::before {
            content: '';
            display: block;
            height: 2px;
            background: var(--spectrum-gradient);
            margin: 0 auto 24px;
            max-width: 200px;
            border-radius: 1px;
        }

        .footer-brand {
            font-weight: 600;
            background: var(--spectrum-gradient);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        /* Pulse animation for severity dots */
        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.5; }
        }

        /* Filters */
        .filter-panel {
            background: var(--bg-secondary);
            border-radius: var(--radius-md);
            padding: 12px 16px;
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
            gap: 12px;
            align-items: end;
            margin-bottom: 16px;
        }

        .filter-group {
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        .filter-label {
            font-size: 12px;
            color: var(--text-secondary);
        }

        .filter-control {
            height: 34px;
            border-radius: var(--radius-sm);
            border: 1px solid var(--border);
            padding: 0 10px;
            font-size: 13px;
            background: white;
            color: var(--text-primary);
        }

        .filter-control:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 2px rgba(51, 112, 255, 0.15);
        }

        .filter-actions {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
        }

        .filter-btn {
            padding: 6px 12px;
            border: 1px solid var(--border);
            background: white;
            border-radius: var(--radius-sm);
            cursor: pointer;
            font-size: 12px;
            color: var(--text-secondary);
            transition: all 0.2s;
        }

        .filter-btn:hover {
            border-color: var(--primary);
            color: var(--primary);
        }

        .filter-btn.primary {
            background: var(--primary);
            color: white;
            border-color: var(--primary);
        }

        .filter-btn.primary:hover {
            background: var(--primary-hover);
            border-color: var(--primary-hover);
        }

        /* Chart Section */
        .chart-section {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 24px;
            margin-top: 24px;
        }

        .chart-container {
            background: var(--bg-secondary);
            border-radius: var(--radius-md);
            padding: 20px;
        }

        .chart-title {
            font-size: 14px;
            font-weight: 600;
            color: var(--text-secondary);
            margin-bottom: 16px;
            text-align: center;
        }

        .chart-canvas {
            max-width: 100%;
            margin: 0 auto;
        }

        /* Pie Chart Legend */
        .chart-legend {
            display: flex;
            flex-wrap: wrap;
            gap: 16px;
            justify-content: center;
            margin-top: 16px;
        }

        .legend-item {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 13px;
            color: var(--text-secondary);
        }

        .legend-color {
            width: 12px;
            height: 12px;
            border-radius: 2px;
        }

        /* Bar Chart */
        .bar-chart {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .bar-item {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .bar-label {
            min-width: 120px;
            font-size: 12px;
            color: var(--text-secondary);
            text-align: right;
        }

        .bar-track {
            flex: 1;
            height: 24px;
            background: var(--bg-primary);
            border-radius: var(--radius-sm);
            overflow: hidden;
            position: relative;
        }

        .bar-fill {
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: flex-end;
            padding-right: 8px;
            font-size: 11px;
            color: white;
            font-weight: 600;
            transition: width 0.3s ease;
        }

        .bar-fill.critical { background: var(--error); }
        .bar-fill.warning { background: var(--warning); }
        .bar-fill.info { background: var(--primary); }
        .bar-fill.success { background: var(--success); }

        .bar-value {
            min-width: 40px;
            text-align: left;
            font-size: 13px;
            font-weight: 600;
            color: var(--text-primary);
        }

        /* Empty State */
        .empty-state {
            text-align: center;
            padding: 60px 24px;
            color: var(--text-secondary);
        }

        .empty-icon {
            font-size: 48px;
            margin-bottom: 16px;
            opacity: 0.5;
        }

        /* Back to Top */
        .back-to-top {
            position: fixed;
            bottom: 30px;
            right: 30px;
            width: 40px;
            height: 40px;
            background: var(--primary);
            color: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            box-shadow: var(--shadow-md);
            opacity: 0;
            visibility: hidden;
            transition: all 0.3s;
            z-index: 100;
            font-size: 20px;
        }

        .back-to-top.visible {
            opacity: 1;
            visibility: visible;
        }

        .back-to-top:hover {
            background: var(--primary-hover);
            transform: translateY(-2px);
        }

        /* Responsive */
        @media (max-width: 768px) {
            .container {
                padding: 0 16px;
            }

            .overview {
                grid-template-columns: 1fr;
                text-align: center;
            }

            .card-body {
                padding: 16px;
            }

            .stats-grid {
                grid-template-columns: repeat(2, 1fr);
            }

            table {
                font-size: 12px;
            }

            thead th, tbody td {
                padding: 10px 12px;
            }
        }
    </style>
</head>
<body>
    <!-- Header -->
    <div class="header">
        <div class="header-content">
            <!-- Logo SVG -->
            <div class="header-logo">
                <svg viewBox="0 0 48 48" width="48" height="48" xmlns="http://www.w3.org/2000/svg">
                    <defs>
                        <linearGradient id="spectrumGrad" x1="0%" y1="0%" x2="100%" y2="0%">
                            <stop offset="0%" style="stop-color:#FF4D4F"/>
                            <stop offset="20%" style="stop-color:#FF7A45"/>
                            <stop offset="40%" style="stop-color:#FFC53D"/>
                            <stop offset="60%" style="stop-color:#52C41A"/>
                            <stop offset="80%" style="stop-color:#1890FF"/>
                            <stop offset="100%" style="stop-color:#722ED1"/>
                        </linearGradient>
                    </defs>
                    <!-- Prism -->
                    <polygon points="24,6 38,38 10,38" fill="none" stroke="#FFFFFF" stroke-width="2"/>
                    <!-- Incident light -->
                    <line x1="2" y1="22" x2="16" y2="22" stroke="#FFFFFF" stroke-width="2"/>
                    <!-- Spectrum rays -->
                    <line x1="32" y1="20" x2="46" y2="14" stroke="#FF4D4F" stroke-width="1.5"/>
                    <line x1="32" y1="22" x2="46" y2="20" stroke="#FF7A45" stroke-width="1.5"/>
                    <line x1="32" y1="24" x2="46" y2="26" stroke="#FFC53D" stroke-width="1.5"/>
                    <line x1="32" y1="26" x2="46" y2="32" stroke="#52C41A" stroke-width="1.5"/>
                    <line x1="32" y1="28" x2="46" y2="38" stroke="#1890FF" stroke-width="1.5"/>
                </svg>
            </div>
            <div class="header-info">
                <h1>光谱 SQL Checker</h1>
                <div class="header-subtitle">SQL 质量检测报告</div>
            </div>
            <div class="header-meta">
                <div>生成时间: {{ summary.generatedAt | date("yyyy-MM-dd HH:mm:ss") }}</div>
                {% if summary.durationMs > 0 %}
                <div>扫描耗时: {{ (summary.durationMs / 1000) | numberFormat }}s</div>
                {% endif %}
            </div>
        </div>
    </div>

    <!-- Main Content -->
    <div class="container">
        <!-- Summary Card -->
        <div class="card">
            <div class="card-header">
                <div class="card-title">
                    <span class="card-icon" style="background: var(--primary-light);">📊</span>
                    扫描概览
                </div>
            </div>
            <div class="card-body">
                <div class="scan-meta">
                    <div class="scan-meta-item">
                        <span class="scan-meta-label">项目</span>
                        <span class="scan-meta-value">{{ summary.projectName | default('未命名项目') }}</span>
                    </div>
                    {% if summary.scanPath %}
                    <div class="scan-meta-item scan-meta-path">
                        <span class="scan-meta-label">路径</span>
                        <span class="scan-meta-value" title="{{ summary.scanPath }}">{{ summary.scanPath }}</span>
                    </div>
                    {% endif %}
                    <div class="scan-meta-item">
                        <span class="scan-meta-label">文件</span>
                        <span class="scan-meta-value">{{ summary.totalFiles }}</span>
                        <span class="scan-meta-sub">Java {{ summary.javaFiles }} · XML {{ summary.xmlFiles }} · SQL {{ summary.sqlFiles }}</span>
                    </div>
                </div>
                <div class="overview">
                    <div class="overview-score">
                        {% if summary.averageScore >= 80 %}
                        <div class="score-badge excellent has-tooltip" data-tooltip="{{ summary.scoreFormula | default('') }}">{{ summary.averageScore | numberFormat }}</div>
                        {% elseif summary.averageScore >= 60 %}
                        <div class="score-badge good has-tooltip" data-tooltip="{{ summary.scoreFormula | default('') }}">{{ summary.averageScore | numberFormat }}</div>
                        {% else %}
                        <div class="score-badge poor has-tooltip" data-tooltip="{{ summary.scoreFormula | default('') }}">{{ summary.averageScore | numberFormat }}</div>
                        {% endif %}
                        <div class="overview-label">平均得分</div>
                    </div>
                    <div class="kpi-grid">
                        <div class="kpi-card">
                            <div class="kpi-label">SQL 总量</div>
                            <div class="kpi-value">{{ summary.totalSql }}</div>
                        </div>
                        <div class="kpi-card">
                            <div class="kpi-label">解析成功</div>
                            <div class="kpi-value">{{ summary.parsedSql }}</div>
                            <div class="kpi-sub">{{ summary.parseRate | numberFormat }}% 解析率</div>
                        </div>
                        <div class="kpi-card">
                            <div class="kpi-label">可执行 EXPLAIN</div>
                            <div class="kpi-value">{{ summary.explainEligible }}</div>
                        </div>
                        <div class="kpi-card">
                            <div class="kpi-label">已执行 EXPLAIN</div>
                            <div class="kpi-value">{{ summary.explainExecuted }}</div>
                            <div class="kpi-sub">{{ summary.explainCoverage | numberFormat }}% 覆盖率</div>
                        </div>
                        <div class="kpi-card">
                            <div class="kpi-label">问题总量</div>
                            <div class="kpi-value">{{ summary.totalIssues }}</div>
                            <div class="kpi-sub">
                                严重 {{ summary.criticalIssues }} · 警告 {{ summary.warningIssues }} · 提示 {{ summary.infoIssues }}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Coverage & Distribution -->
        <div class="card">
            <div class="card-header">
                <div class="card-title">
                    <span class="card-icon" style="background: var(--primary-light);">🧭</span>
                    覆盖率与分布
                </div>
            </div>
            <div class="card-body">
                <div class="insight-grid">
                    <div class="insight-card">
                        <div class="insight-title">解析与 EXPLAIN 覆盖率</div>
                        <div class="progress-group">
                            <div>
                                <div class="progress-label">
                                    <span>解析覆盖率</span>
                                    <span>{{ summary.parsedSql }}/{{ summary.totalSql }}</span>
                                </div>
                                <div class="progress-track">
                                    <div class="progress-fill" style="width: {{ summary.parseRate | numberFormat }}%;"></div>
                                </div>
                            </div>
                            <div>
                                <div class="progress-label">
                                    <span>EXPLAIN 覆盖率</span>
                                    <span>{{ summary.explainExecuted }}/{{ summary.explainEligible }}</span>
                                </div>
                                <div class="progress-track">
                                    <div class="progress-fill" style="width: {{ summary.explainCoverage | numberFormat }}%;"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="insight-card">
                        <div class="insight-title">SQL 分类</div>
                        <div class="stat-list">
                            {% if summary.categoryStats is empty %}
                            <div class="stat-row-label">暂无数据</div>
                            {% else %}
                            {% for item in summary.categoryStats %}
                            <div class="stat-row">
                                <div class="stat-row-label">{{ item.label }}</div>
                                <div class="stat-row-track">
                                    <div class="stat-row-fill" style="width: {{ item.ratio | numberFormat }}%;"></div>
                                </div>
                                <div class="stat-row-value">{{ item.count }}</div>
                            </div>
                            {% endfor %}
                            {% endif %}
                        </div>
                    </div>
                    <div class="insight-card">
                        <div class="insight-title">EXPLAIN 可执行性</div>
                        <div class="stat-list">
                            {% if summary.explainEligibilityStats is empty %}
                            <div class="stat-row-label">暂无数据</div>
                            {% else %}
                            {% for item in summary.explainEligibilityStats %}
                            <div class="stat-row">
                                <div class="stat-row-label">{{ item.label }}</div>
                                <div class="stat-row-track">
                                    <div class="stat-row-fill" style="width: {{ item.ratio | numberFormat }}%;"></div>
                                </div>
                                <div class="stat-row-value">{{ item.count }}</div>
                            </div>
                            {% endfor %}
                            {% endif %}
                        </div>
                    </div>
                    <div class="insight-card">
                        <div class="insight-title">SQL 来源类型</div>
                        <div class="stat-list">
                            {% if summary.sourceTypeStats is empty %}
                            <div class="stat-row-label">暂无数据</div>
                            {% else %}
                            {% for item in summary.sourceTypeStats %}
                            <div class="stat-row">
                                <div class="stat-row-label">{{ item.label }}</div>
                                <div class="stat-row-track">
                                    <div class="stat-row-fill" style="width: {{ item.ratio | numberFormat }}%;"></div>
                                </div>
                                <div class="stat-row-value">{{ item.count }}</div>
                            </div>
                            {% endfor %}
                            {% endif %}
                        </div>
                    </div>
                    <div class="insight-card">
                        <div class="insight-title">合法性</div>
                        <div class="stat-list">
                            {% if summary.validityStats is empty %}
                            <div class="stat-row-label">暂无数据</div>
                            {% else %}
                            {% for item in summary.validityStats %}
                            <div class="stat-row">
                                <div class="stat-row-label">{{ item.label }}</div>
                                <div class="stat-row-track">
                                    <div class="stat-row-fill" style="width: {{ item.ratio | numberFormat }}%;"></div>
                                </div>
                                <div class="stat-row-value">{{ item.count }}</div>
                            </div>
                            {% endfor %}
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Issue Hotspots -->
        <div class="card">
            <div class="card-header">
                <div class="card-title">
                    <span class="card-icon" style="background: var(--primary-light);">🔥</span>
                    问题热点
                </div>
            </div>
            <div class="card-body">
                <div class="insight-grid">
                    <div class="insight-card">
                        <div class="insight-title">静态规则</div>
                        <div class="stat-list">
                            {% if summary.staticIssueStats is empty %}
                            <div class="stat-row-label">暂无静态问题</div>
                            {% else %}
                            {% for item in summary.staticIssueStats %}
                            <div class="stat-row">
                                <div class="stat-row-label">{{ item.label }}</div>
                                <div class="stat-row-track">
                                    <div class="stat-row-fill" style="width: {{ item.ratio | numberFormat }}%;"></div>
                                </div>
                                <div class="stat-row-value">{{ item.count }}</div>
                            </div>
                            {% endfor %}
                            {% endif %}
                        </div>
                    </div>
                    <div class="insight-card">
                        <div class="insight-title">EXPLAIN 规则</div>
                        <div class="stat-list">
                            {% if summary.explainIssueStats is empty %}
                            <div class="stat-row-label">暂无 EXPLAIN 问题</div>
                            {% else %}
                            {% for item in summary.explainIssueStats %}
                            <div class="stat-row">
                                <div class="stat-row-label">{{ item.label }}</div>
                                <div class="stat-row-track">
                                    <div class="stat-row-fill" style="width: {{ item.ratio | numberFormat }}%;"></div>
                                </div>
                                <div class="stat-row-value">{{ item.count }}</div>
                            </div>
                            {% endfor %}
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Charts Section -->
        {% if summary.totalIssues > 0 %}
        <div class="card">
            <div class="card-header">
                <div class="card-title">
                    <span class="card-icon" style="background: var(--primary-light);">📈</span>
                    问题分布
                </div>
            </div>
            <div class="card-body">
                <div class="chart-section">
                    <!-- Pie Chart -->
                    <div class="chart-container">
                        <div class="chart-title">严重程度分布</div>
                        <canvas id="pieChart" class="chart-canvas" width="200" height="200"></canvas>
                        <div class="chart-legend">
                            <div class="legend-item">
                                <div class="legend-color" style="background: var(--error);"></div>
                                <span>严重 ({{ summary.criticalIssues }})</span>
                            </div>
                            <div class="legend-item">
                                <div class="legend-color" style="background: var(--warning);"></div>
                                <span>警告 ({{ summary.warningIssues }})</span>
                            </div>
                            <div class="legend-item">
                                <div class="legend-color" style="background: var(--primary);"></div>
                                <span>提示 ({{ summary.infoIssues }})</span>
                            </div>
                        </div>
                    </div>

                    <!-- Bar Chart -->
                    <div class="chart-container">
                        <div class="chart-title">问题构成（静态 / EXPLAIN）</div>
                        <div class="bar-chart" id="barChart">
                            {% set issueTotal = summary.staticIssueTotal + summary.explainIssueTotal %}
                            {% if issueTotal > 0 %}
                            {% if summary.staticIssueTotal > 0 %}
                            <div class="bar-item">
                                <div class="bar-label">静态规则</div>
                                <div class="bar-track">
                                    <div class="bar-fill info" style="width: {{ (summary.staticIssueTotal * 100 / issueTotal) | numberFormat }}%;">
                                        {{ (summary.staticIssueTotal * 100 / issueTotal) | numberFormat }}%
                                    </div>
                                </div>
                                <div class="bar-value">{{ summary.staticIssueTotal }}</div>
                            </div>
                            {% endif %}
                            {% if summary.explainIssueTotal > 0 %}
                            <div class="bar-item">
                                <div class="bar-label">EXPLAIN 规则</div>
                                <div class="bar-track">
                                    <div class="bar-fill success" style="width: {{ (summary.explainIssueTotal * 100 / issueTotal) | numberFormat }}%;">
                                        {{ (summary.explainIssueTotal * 100 / issueTotal) | numberFormat }}%
                                    </div>
                                </div>
                                <div class="bar-value">{{ summary.explainIssueTotal }}</div>
                            </div>
                            {% endif %}
                            {% else %}
                            <div class="stat-row-label">暂无数据</div>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        </div>
        {% endif %}

        <!-- SQL List -->
        <div class="card">
            <div class="card-header">
                <div class="card-title">
                    <span class="card-icon" style="background: var(--primary-light);">📝</span>
                    SQL 语句列表 ({{ sqlStatements | length }})
                </div>
            </div>
            <div class="card-body">
                <form class="filter-panel" id="sql-filter-form">
                    <div class="filter-group">
                        <label class="filter-label" for="filter-severity">严重级别</label>
                        <select class="filter-control" id="filter-severity">
                            <option value="all">全部</option>
                            <option value="critical">严重</option>
                            <option value="warning">警告</option>
                            <option value="info">提示</option>
                        </select>
                    </div>
                    <div class="filter-group">
                        <label class="filter-label" for="filter-category">SQL 分类</label>
                        <select class="filter-control" id="filter-category">
                            <option value="all">全部</option>
                            <option value="mybatis_xml_static">MyBatis XML 静态</option>
                            <option value="mybatis_xml_dynamic">MyBatis XML 动态</option>
                            <option value="mybatis_annotation">MyBatis 注解</option>
                            <option value="jpa_native_query">JPA 原生查询</option>
                            <option value="string_concat">字符串拼接</option>
                            <option value="placeholder_template">占位符模板</option>
                            <option value="unknown">未知</option>
                        </select>
                    </div>
                    <div class="filter-group">
                        <label class="filter-label" for="filter-validity">合法性</label>
                        <select class="filter-control" id="filter-validity">
                            <option value="all">全部</option>
                            <option value="valid">合法</option>
                            <option value="invalid">非法</option>
                            <option value="unknown">未知</option>
                        </select>
                    </div>
                    <div class="filter-group">
                        <label class="filter-label" for="filter-explain">EXPLAIN 可执行性</label>
                        <select class="filter-control" id="filter-explain">
                            <option value="all">全部</option>
                            <option value="supported">可执行</option>
                            <option value="not_supported">不支持</option>
                            <option value="skipped">已跳过</option>
                            <option value="unknown">未知</option>
                        </select>
                    </div>
                    <div class="filter-group">
                        <label class="filter-label" for="filter-source">来源类型</label>
                        <select class="filter-control" id="filter-source">
                            <option value="all">全部</option>
                            <option value="java">Java</option>
                            <option value="javascript">JavaScript/TypeScript</option>
                            <option value="mybatis">MyBatis XML</option>
                            <option value="mybatis_annotation">MyBatis 注解</option>
                            <option value="jpa_annotation">JPA 注解</option>
                            <option value="string_literal">字符串拼接</option>
                            <option value="sql_file">SQL 文件</option>
                            <option value="unknown">未知</option>
                        </select>
                    </div>
                    <div class="filter-group">
                        <label class="filter-label" for="filter-score-min">评分区间</label>
                        <div style="display: flex; gap: 8px;">
                            <input class="filter-control" id="filter-score-min" type="number" min="0" max="100" placeholder="最低">
                            <input class="filter-control" id="filter-score-max" type="number" min="0" max="100" placeholder="最高">
                        </div>
                    </div>
                    <div class="filter-group">
                        <label class="filter-label" for="filter-rule-type">规则类型</label>
                        <select class="filter-control" id="filter-rule-type">
                            <option value="all">全部</option>
                            <option value="static">静态规则</option>
                            <option value="explain">EXPLAIN 规则</option>
                        </select>
                    </div>
                    <div class="filter-group">
                        <label class="filter-label" for="filter-issue-min">最小问题数</label>
                        <input class="filter-control" id="filter-issue-min" type="number" min="0" placeholder="如 1">
                    </div>
                    <div class="filter-group">
                        <label class="filter-label" for="filter-rule-keyword">规则关键词</label>
                        <input class="filter-control" id="filter-rule-keyword" type="text" placeholder="规则名称/描述">
                    </div>
                    <div class="filter-group">
                        <label class="filter-label" for="filter-keyword">关键词</label>
                        <input class="filter-control" id="filter-keyword" type="text" placeholder="SQL / 文件 / 规则">
                    </div>
                    <div class="filter-group">
                        <label class="filter-label">操作</label>
                        <div class="filter-actions">
                            <button class="filter-btn primary" type="button" onclick="applyFilters()">应用筛选</button>
                            <button class="filter-btn" type="button" onclick="resetFilters()">清空</button>
                        </div>
                    </div>
                </form>

                {% if sqlStatements is empty %}
                <div class="empty-state">
                    <div class="empty-icon">✓</div>
                    <p>未发现 SQL 语句</p>
                </div>
                {% else %}
                <div class="table-container">
                    <table>
                        <thead>
                            <tr>
                                <th style="width: 80px;">严重级别</th>
                                <th style="width: 80px;">评分</th>
                                <th>SQL 语句</th>
                                <th style="width: 120px;">位置</th>
                                <th style="width: 80px;">详情</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for sql in sqlStatements %}
                            {% set sourceType = (sql.locations is not empty and sql.locations[0].sourceType is not null) ? (sql.locations[0].sourceType | lower) : 'unknown' %}
                            {% set searchText = (sql.abstractSql | default('')) ~ ' ' ~ (sql.originalSql | default('')) ~ ' ' ~ (sql.locations is not empty ? (sql.locations[0].fileName | default('')) : '') %}
                            {% set staticIssueCount = (sql.staticAnalysis is defined and sql.staticAnalysis is not null and sql.staticAnalysis.issues is not null) ? sql.staticAnalysis.issues.size() : 0 %}
                            {% set explainIssueCount = (sql.explainAnalysis is defined and sql.explainAnalysis is not null and sql.explainAnalysis.issues is not null) ? sql.explainAnalysis.issues.size() : 0 %}
                            {% set totalIssueCount = staticIssueCount + explainIssueCount %}
                            {% set ruleKeywords = '' %}
                            {% if sql.staticAnalysis is defined and sql.staticAnalysis is not null and sql.staticAnalysis.issues is not null %}
                                {% for issue in sql.staticAnalysis.issues %}
                                    {% set ruleKeywords = ruleKeywords ~ ' ' ~ (issue.type | default('')) ~ ' ' ~ (issue.message | default('')) %}
                                {% endfor %}
                            {% endif %}
                            {% if sql.explainAnalysis is defined and sql.explainAnalysis is not null and sql.explainAnalysis.issues is not null %}
                                {% for issue in sql.explainAnalysis.issues %}
                                    {% set ruleKeywords = ruleKeywords ~ ' ' ~ (issue.type | default('')) ~ ' ' ~ (issue.message | default('')) %}
                                {% endfor %}
                            {% endif %}
                            <tr data-severity="{{ sql.severity | default('info') | lower }}"
                                data-category="{{ sql.category | default('unknown') | lower }}"
                                data-validity="{{ sql.validity | default('unknown') | lower }}"
                                data-explain="{{ sql.explainEligibility | default('unknown') | lower }}"
                                data-source="{{ sourceType }}"
                                data-score="{{ sql.score | default(0) }}"
                                data-search="{{ searchText | lower }}"
                                data-static-count="{{ staticIssueCount }}"
                                data-explain-count="{{ explainIssueCount }}"
                                data-issue-count="{{ totalIssueCount }}"
                                data-rule-keywords="{{ ruleKeywords | lower }}"
                                data-sql-id="{{ sql.id }}">
                                <td>
                                    <span class="severity-badge {{ sql.severity | lower }}">
                                        <span class="severity-dot"></span>
                                        {% if sql.severity == 'CRITICAL' %}严重
                                        {% elseif sql.severity == 'WARNING' %}警告
                                        {% else %}提示{% endif %}
                                    </span>
                                </td>
                                <td>
                                    <strong class="has-tooltip" data-tooltip="{{ sql.scoreExplanation | default('') }}">{{ sql.score }}</strong>
                                </td>
                                <td>
                                    <div class="sql-code-container">
                                        <div class="sql-code highlight-sql">{{ sql.abstractSql }}</div>
                                        <button class="copy-btn" onclick="copyToClipboard(this)">复制</button>
                                    </div>
                                    {% if sql.originalSql != sql.abstractSql %}
                                    <details style="margin-top: 8px;">
                                        <summary style="cursor: pointer; color: var(--primary); font-size: 12px;">查看原始 SQL</summary>
                                        <div class="sql-code-container" style="margin-top: 8px;">
                                            <div class="sql-code highlight-sql">{{ sql.originalSql }}</div>
                                            <button class="copy-btn" onclick="copyToClipboard(this)">复制</button>
                                        </div>
                                    </details>
                                    {% endif %}
                                </td>
                                <td>
                                    {% for location in sql.locations %}
                                    <span class="location-tag">{{ location.fileName }}:{{ location.startLine }}</span>
                                    {% endfor %}
                                </td>
                                <td>
                                    <button class="filter-btn" onclick="toggleDetails('{{ sql.id }}')">查看</button>
                                </td>
                            </tr>

                            <!-- Details Row (Hidden by default) -->
                            <tr id="details-{{ sql.id }}" style="display: none;">
                                <td colspan="5" style="padding: 0;">
                                    <div style="padding: 14px; background: var(--bg-secondary);">
                                        <!-- Preprocess Info -->
                                        <h4 style="margin-bottom: 8px;">🧹 预处理信息</h4>
                                        <div style="font-size: 12px; color: var(--text-secondary); margin-bottom: 6px;">
                                            分类: {{ sql.category }} |
                                            合法性: {{ sql.validity }} |
                                            Explain 可执行性: {{ sql.explainEligibility }}
                                        </div>
                                        {% if sql.preprocessErrorReason %}
                                        <div style="font-size: 12px; color: var(--warning); margin-bottom: 6px;">
                                            {{ sql.preprocessErrorReason }}
                                        </div>
                                        {% endif %}
                                        {% if sql.normalizedSql %}
                                        <details style="margin-bottom: 8px;">
                                            <summary style="cursor: pointer; color: var(--primary); font-size: 12px;">查看规范化 SQL</summary>
                                            <div class="sql-code" style="margin-top: 8px;">{{ sql.normalizedSql }}</div>
                                        </details>
                                        {% endif %}
                                        {% if sql.explainSql %}
                                        <details style="margin-bottom: 12px;">
                                            <summary style="cursor: pointer; color: var(--primary); font-size: 12px;">查看 Explain SQL</summary>
                                            <div class="sql-code-container" style="margin-top: 8px;">
                                                <div class="sql-code highlight-sql">{{ sql.explainSql }}</div>
                                                <button class="copy-btn" onclick="copyToClipboard(this)">复制</button>
                                            </div>
                                        </details>
                                        {% endif %}
                                        <!-- Static Analysis -->
                                        {% if sql.staticAnalysis is defined and sql.staticAnalysis is not null %}
                                        <h4 style="margin-bottom: 8px;">📋 静态分析结果</h4>
                                        {% if sql.staticAnalysis.issues is defined and sql.staticAnalysis.issues is not null and sql.staticAnalysis.issues.size() > 0 %}
                                        <ul class="issue-list">
                                            {% for issue in sql.staticAnalysis.issues %}
                                            <li class="issue-item">
                                                <span class="issue-icon {{ issue.severity | lower }}">!</span>
                                                <div class="issue-content">
                                                    <div class="issue-message">{{ issue.message }}</div>
                                                    {% if issue.suggestion %}
                                                    <div class="issue-suggestion">💡 {{ issue.suggestion }}</div>
                                                    {% endif %}
                                                </div>
                                            </li>
                                            {% endfor %}
                                        </ul>
                                        {% else %}
                                        <p style="color: var(--text-secondary);">未发现问题</p>
                                        {% endif %}
                                        {% else %}
                                        <h4 style="margin-bottom: 8px;">📋 静态分析结果</h4>
                                        <p style="color: var(--text-secondary);">未发现问题</p>
                                        {% endif %}

                                        <!-- EXPLAIN Analysis -->
                                        {% if sql.explainEligibility is defined and sql.explainEligibility == 'NOT_SUPPORTED' %}
                                        <h4 style="margin: 12px 0 8px;">📊 执行计划分析 (EXPLAIN)</h4>
                                        <p style="color: var(--text-secondary);">
                                            已跳过: {{ sql.explainEligibility }}
                                            {% if sql.preprocessErrorReason %} ({{ sql.preprocessErrorReason }}){% endif %}
                                        </p>
                                        {% elseif sql.explainAnalysis is defined and sql.explainAnalysis is not null and sql.explainAnalysis.plan is defined and sql.explainAnalysis.plan is not null %}
                                        <h4 style="margin: 12px 0 8px;">📊 执行计划分析 (EXPLAIN)</h4>
                                        <div class="explain-plan">
                                            {% for node in sql.explainAnalysis.plan.nodes %}
                                            <div class="explain-node {{ node.id == '1' ? 'root' : '' }}">
                                                <span class="explain-type">{{ node.selectType }}</span>
                                                <span> | </span>
                                                <span class="explain-type">{{ node.type }}</span>
                                                <span> | </span>
                                                <span class="explain-table">{{ node.table }}</span>
                                                {% if node.key %}
                                                <span> | 索引: {{ node.key }}</span>
                                                {% endif %}
                                                {% if node.rows %}
                                                <span> | 扫描行数: {{ node.rows }}</span>
                                                {% endif %}
                                                {% if node.extra %}
                                                <div style="color: var(--text-secondary); margin-top: 4px;">{{ node.extra }}</div>
                                                {% endif %}
                                            </div>
                                            {% endfor %}
                                        </div>
                                        {% if sql.explainAnalysis.issues is defined and sql.explainAnalysis.issues is not null and sql.explainAnalysis.issues.size() > 0 %}
                                        <ul class="issue-list" style="margin-top: 8px;">
                                            {% for issue in sql.explainAnalysis.issues %}
                                            <li class="issue-item">
                                                <span class="issue-icon {{ issue.severity | lower }}">!</span>
                                                <div class="issue-content">
                                                    <div class="issue-message">{{ issue.message }}</div>
                                                    {% if issue.suggestion %}
                                                    <div class="issue-suggestion">💡 {{ issue.suggestion }}</div>
                                                    {% endif %}
                                                </div>
                                            </li>
                                            {% endfor %}
                                        </ul>
                                        {% endif %}
                                        {% elseif sql.explainAnalysis is defined and sql.explainAnalysis is not null %}
                                        <h4 style="margin: 12px 0 8px;">📊 执行计划分析 (EXPLAIN)</h4>
                                        <p style="color: var(--text-secondary);">动态分析需要配置数据库连接，当前未启用</p>
                                        {% else %}
                                        <h4 style="margin: 12px 0 8px;">📊 执行计划分析 (EXPLAIN)</h4>
                                        <p style="color: var(--text-secondary);">动态分析需要配置数据库连接，当前未启用</p>
                                        {% endif %}

                                        <!-- Expert Analysis -->
                                        {% if sql.expertAnalysis is defined and sql.expertAnalysis is not null and sql.expertAnalysis.recommendations is defined and sql.expertAnalysis.recommendations is not null and sql.expertAnalysis.recommendations.size() > 0 %}
                                        <h4 style="margin: 12px 0 8px;">🎯 专家建议</h4>
                                        <ul class="issue-list">
                                            {% for rec in sql.expertAnalysis.recommendations %}
                                            <li class="issue-item">
                                                <span class="issue-icon info">★</span>
                                                <div class="issue-content">
                                                    <div class="issue-message">{{ rec.title }}</div>
                                                    <div style="font-size: 13px; color: var(--text-secondary); margin: 4px 0;">{{ rec.description }}</div>
                                                    <div class="issue-suggestion">💡 {{ rec.suggestion }}</div>
                                                    {% if rec.expectedBenefit %}
                                                    <div style="font-size: 12px; color: var(--success); margin-top: 4px;">
                                                        ✓ {{ rec.expectedBenefit }}
                                                    </div>
                                                    {% endif %}
                                                </div>
                                            </li>
                                            {% endfor %}
                                        </ul>
                                        {% else %}
                                        {% if sql.expertAnalysis is defined and sql.expertAnalysis is not null %}
                                        <h4 style="margin: 20px 0 12px;">🎯 专家建议</h4>
                                        <p style="color: var(--text-secondary);">暂无建议</p>
                                        {% endif %}
                                        {% endif %}
                                    </div>
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
                {% endif %}
            </div>
        </div>
    </div>

    <div class="back-to-top" onclick="window.scrollTo({top: 0, behavior: 'smooth'})">
        ↑
    </div>

    <!-- Footer -->
    <div class="footer">
        <p>由 <span class="footer-brand">光谱 SQL Checker</span> 生成 | v1.0.0</p>
        <p style="margin-top: 8px; font-size: 12px;">扫描耗时: {{ (summary.durationMs / 1000) | numberFormat }}秒</p>
    </div>

    <script>
        // Chart data from template
        const chartData = {
            critical: {{ summary.criticalIssues }},
            warning: {{ summary.warningIssues }},
            info: {{ summary.infoIssues }},
            total: {{ summary.totalIssues }}
        };

        // Draw pie chart
        function drawPieChart() {
            const canvas = document.getElementById('pieChart');
            if (!canvas) return;

            const ctx = canvas.getContext('2d');
            const centerX = canvas.width / 2;
            const centerY = canvas.height / 2;
            const radius = Math.min(centerX, centerY) - 10;

            // Spectrum colors for chart
            const data = [
                { value: chartData.critical, color: '#FF4D4F', label: 'Critical' },
                { value: chartData.warning, color: '#FF7A45', label: 'Warning' },
                { value: chartData.info, color: '#597EF7', label: 'Info' }
            ].filter(d => d.value > 0);

            if (data.length === 0) {
                // Draw empty state
                ctx.beginPath();
                ctx.arc(centerX, centerY, radius, 0, 2 * Math.PI);
                ctx.fillStyle = '#DEE0E3';
                ctx.fill();
                return;
            }

            const total = data.reduce((sum, d) => sum + d.value, 0);
            let startAngle = -Math.PI / 2;

            data.forEach(item => {
                const sliceAngle = (item.value / total) * 2 * Math.PI;

                ctx.beginPath();
                ctx.moveTo(centerX, centerY);
                ctx.arc(centerX, centerY, radius, startAngle, startAngle + sliceAngle);
                ctx.closePath();
                ctx.fillStyle = item.color;
                ctx.fill();

                // Add white border between slices
                ctx.strokeStyle = '#FFFFFF';
                ctx.lineWidth = 2;
                ctx.stroke();

                startAngle += sliceAngle;
            });

            // Draw center circle (donut chart style)
            ctx.beginPath();
            ctx.arc(centerX, centerY, radius * 0.5, 0, 2 * Math.PI);
            ctx.fillStyle = '#F5F6F7';
            ctx.fill();

            // Draw total in center
            ctx.fillStyle = '#1F2329';
            ctx.font = 'bold 24px sans-serif';
            ctx.textAlign = 'center';
            ctx.textBaseline = 'middle';
            ctx.fillText(total.toString(), centerX, centerY);
        }

        // Toggle details
        function toggleDetails(id) {
            const row = document.getElementById('details-' + id);
            if (!row) return;
            if (row.style.display === 'none') {
                row.style.display = 'table-row';
            } else {
                row.style.display = 'none';
            }
        }

        function getFilterValues() {
            const severity = document.getElementById('filter-severity')?.value || 'all';
            const category = document.getElementById('filter-category')?.value || 'all';
            const validity = document.getElementById('filter-validity')?.value || 'all';
            const explain = document.getElementById('filter-explain')?.value || 'all';
            const source = document.getElementById('filter-source')?.value || 'all';
            const minScore = document.getElementById('filter-score-min')?.value || '';
            const maxScore = document.getElementById('filter-score-max')?.value || '';
            const ruleType = document.getElementById('filter-rule-type')?.value || 'all';
            const minIssues = document.getElementById('filter-issue-min')?.value || '';
            const ruleKeyword = (document.getElementById('filter-rule-keyword')?.value || '').trim().toLowerCase();
            const keyword = (document.getElementById('filter-keyword')?.value || '').trim().toLowerCase();
            return { severity, category, validity, explain, source, minScore, maxScore, ruleType, minIssues, ruleKeyword, keyword };
        }

        function applyFilters() {
            const filters = getFilterValues();
            const rows = document.querySelectorAll('tbody tr[data-severity]');

            rows.forEach(row => {
                const severity = row.dataset.severity || 'info';
                const category = row.dataset.category || 'unknown';
                const validity = row.dataset.validity || 'unknown';
                const explain = row.dataset.explain || 'unknown';
                const source = row.dataset.source || 'unknown';
                const score = parseInt(row.dataset.score || '0', 10);
                const search = row.dataset.search || '';
                const staticCount = parseInt(row.dataset.staticCount || '0', 10);
                const explainCount = parseInt(row.dataset.explainCount || '0', 10);
                const issueCount = parseInt(row.dataset.issueCount || '0', 10);
                const ruleKeywords = row.dataset.ruleKeywords || '';

                let visible = true;
                if (filters.severity !== 'all' && severity !== filters.severity) visible = false;
                if (filters.category !== 'all' && category !== filters.category) visible = false;
                if (filters.validity !== 'all' && validity !== filters.validity) visible = false;
                if (filters.explain !== 'all' && explain !== filters.explain) visible = false;
                if (filters.source !== 'all' && source !== filters.source) visible = false;

                if (filters.minScore !== '' && score < parseInt(filters.minScore, 10)) visible = false;
                if (filters.maxScore !== '' && score > parseInt(filters.maxScore, 10)) visible = false;
                if (filters.ruleType === 'static' && staticCount === 0) visible = false;
                if (filters.ruleType === 'explain' && explainCount === 0) visible = false;
                if (filters.minIssues !== '' && issueCount < parseInt(filters.minIssues, 10)) visible = false;
                if (filters.ruleKeyword && !ruleKeywords.includes(filters.ruleKeyword)) visible = false;
                if (filters.keyword && !search.includes(filters.keyword)) visible = false;

                row.style.display = visible ? '' : 'none';

                const detailsRow = document.getElementById('details-' + row.dataset.sqlId);
                if (detailsRow && !visible) {
                    detailsRow.style.display = 'none';
                }
            });
        }

        function resetFilters() {
            const severity = document.getElementById('filter-severity');
            const category = document.getElementById('filter-category');
            const validity = document.getElementById('filter-validity');
            const explain = document.getElementById('filter-explain');
            const source = document.getElementById('filter-source');
            const minScore = document.getElementById('filter-score-min');
            const maxScore = document.getElementById('filter-score-max');
            const ruleType = document.getElementById('filter-rule-type');
            const minIssues = document.getElementById('filter-issue-min');
            const ruleKeyword = document.getElementById('filter-rule-keyword');
            const keyword = document.getElementById('filter-keyword');

            if (severity) severity.value = 'all';
            if (category) category.value = 'all';
            if (validity) validity.value = 'all';
            if (explain) explain.value = 'all';
            if (source) source.value = 'all';
            if (minScore) minScore.value = '';
            if (maxScore) maxScore.value = '';
            if (ruleType) ruleType.value = 'all';
            if (minIssues) minIssues.value = '';
            if (ruleKeyword) ruleKeyword.value = '';
            if (keyword) keyword.value = '';
            applyFilters();
        }

        // Collapsible sections
        document.querySelectorAll('.collapsible-header').forEach(header => {
            header.addEventListener('click', () => {
                header.parentElement.classList.toggle('expanded');
            });
        });

        // Debounce utility
        function debounce(func, wait) {
            let timeout;
            return function(...args) {
                const context = this;
                clearTimeout(timeout);
                timeout = setTimeout(() => func.apply(context, args), wait);
            };
        }

        // Copy to clipboard
        function copyToClipboard(btn) {
            const container = btn.parentElement;
            const codeBlock = container.querySelector('.sql-code');
            const code = codeBlock.innerText || codeBlock.textContent;
            
            navigator.clipboard.writeText(code).then(() => {
                const originalText = btn.textContent;
                btn.textContent = '已复制';
                btn.style.color = '#52C41A';
                btn.style.borderColor = '#52C41A';
                setTimeout(() => {
                    btn.textContent = originalText;
                    btn.style.color = '';
                    btn.style.borderColor = '';
                }, 2000);
            }).catch(err => {
                console.error('Failed to copy: ', err);
                btn.textContent = '失败';
            });
        }

        // Simple SQL Syntax Highlighter
        function highlightSql() {
            const keywords = /\b(SELECT|INSERT|UPDATE|DELETE|FROM|WHERE|AND|OR|GROUP BY|ORDER BY|LIMIT|JOIN|LEFT|RIGHT|INNER|OUTER|ON|AS|IN|IS|NULL|NOT|CREATE|TABLE|DROP|ALTER|INDEX|VIEW|UNION|ALL|HAVING|DISTINCT|CASE|WHEN|THEN|ELSE|END|EXISTS|LIKE|BETWEEN|VALUES|SET|INTO|DESC|ASC|COUNT|SUM|AVG|MAX|MIN)\b/gi;
            const strings = /'[^']*'/g;
            const numbers = /\b\d+\b/g;

            document.querySelectorAll('.highlight-sql').forEach(el => {
                if (el.dataset.highlighted) return;
                
                let html = el.textContent;
                html = html.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
                
                html = html.replace(keywords, '<span class="hl-keyword">$1</span>')
                           .replace(strings, '<span class="hl-string">$&</span>')
                           .replace(numbers, '<span class="hl-number">$&</span>');
                
                el.innerHTML = html;
                el.dataset.highlighted = 'true';
            });
        }
        
        const debouncedApplyFilters = debounce(applyFilters, 300);

        // Initialize charts + filters on page load
        window.addEventListener('load', () => {
            drawPieChart();
            highlightSql();
            // applyFilters();

            const filterForm = document.getElementById('sql-filter-form');
            if (filterForm) {
                filterForm.querySelectorAll('select').forEach(el => {
                    el.addEventListener('change', applyFilters);
                });
                filterForm.querySelectorAll('input').forEach(el => {
                    el.addEventListener('input', debouncedApplyFilters);
                });
            }
            
            // Back to top visibility
            const backToTopBtn = document.querySelector('.back-to-top');
            if (backToTopBtn) {
                window.addEventListener('scroll', () => {
                    if (window.scrollY > 300) {
                        backToTopBtn.classList.add('visible');
                    } else {
                        backToTopBtn.classList.remove('visible');
                    }
                });
            }
        });
    </script>
</body>
</html>
